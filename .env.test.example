# Test Environment Variables
# Copy this file to .env.test and fill in your test values
# NEVER commit the actual .env.test file with real passwords

# Test API Configuration
TEST_API_URL=http://localhost:3001

# Test User Credentials
# Use these instead of hardcoding passwords in test files
TEST_EMAIL=test@example.com
TEST_PASSWORD=YourTestPassword123!

# Admin Credentials for Scripts
# Used by reset-admin-password.js and other admin scripts
ADMIN_PASSWORD=GenerateSecurePasswordHere

# Database Test Credentials
TEST_DB_PASSWORD=TestDatabasePassword

# Note: In production, use a secure password manager or secrets service
# Never commit real passwords to version control